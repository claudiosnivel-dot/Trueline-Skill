{
  "$comment": "authz verified = pocketbase_rules_check statico ri-eseguito pulito (listRule:\"\" -> owner-scoped); NON invarianza runtime (PocketBase non disponibile nel sandbox) — L-COL-006. Trappola critica: null=LOCKED(SAFE), \"\"=PUBLIC(POCKETBASE001). Verificato: null NON produce finding.",
  "id": "pocketbase-jsts",
  "version": "1.0.0",
  "languages": ["js", "ts"],
  "backend": "pocketbase",
  "detect": { "files_any": ["pb_schema.json"], "lang_any": ["package.json"] },
  "triggers": ["pocketbase", "pb_schema", "pb_schema.json", "pocketbase-js-sdk", "pocketbase sdk", "js", "ts", "javascript", "typescript", "blueprint", "audit", "remediat", "bonific", "macrotask", "oracol", "sicur", "security", "secret", "segret"],
  "oracles": {
    "secret":          { "tool": "gitleaks", "shared": true },
    "dependency-vuln": { "tool": "osv", "lockfiles": ["package-lock.json", "pnpm-lock.yaml", "yarn.lock"] },
    "authz":           { "tool": "pocketbase_rules_check", "kind": "pocketbase-rules", "scan": ["."], "role": "authz-surface" },
    "injection":       { "tool": "semgrep", "ruleset": "ruleset/" },
    "dead-code":       { "tool": "knip" }
  },
  "test_runner": { "detect": ["vitest", "jest", "mocha"] },
  "floor":        ["secret", "dependency-vuln", "authz"],
  "verified_set": ["secret", "dead-code", "authz"],
  "coverage_policy": "declared"
}
