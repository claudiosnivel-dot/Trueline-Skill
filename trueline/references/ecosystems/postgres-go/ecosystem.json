{
  "id": "postgres-go",
  "version": "1.0.0",
  "languages": ["go"],
  "backend": "postgres",
  "detect": { "lang_any": ["go.mod"] },
  "triggers": ["go", "golang", "postgres", "pg", "pgx", "database/sql", "secret", "segret", "authz", "authorization", "autorizzazione", "route", "rotta", "endpoint", "blueprint", "audit", "remediat", "bonific", "macrotask", "oracol", "sicur", "security"],
  "oracles": {
    "secret":          { "tool": "gitleaks", "shared": true },
    "dependency-vuln": { "tool": "osv", "lockfiles": ["go.mod", "go.sum"] },
    "authz":           { "tool": "semgrep", "ruleset": "ruleset/", "role": "authz-surface" },
    "injection":       { "tool": "semgrep", "ruleset": "ruleset/" },
    "dead-code":       { "tool": "x/tools/deadcode" }
  },
  "floor":        ["secret", "dependency-vuln", "authz"],
  "verified_set": [],
  "coverage_policy": "declared"
}
