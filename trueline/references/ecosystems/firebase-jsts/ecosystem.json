{
  "id": "firebase-jsts",
  "version": "1.0.0",
  "languages": ["js", "ts"],
  "backend": "firebase",
  "detect": { "files_any": ["firebase.json", "firestore.rules"], "lang_any": ["package.json"] },
  "triggers": ["firebase", "firestore", "firestore.rules", "firebase-admin", "security rules", "authz", "firebase-functions", "cloud functions", "realtime database", "rtdb", "storage.rules", "functions", "js", "ts", "javascript", "typescript", "blueprint", "audit", "remediat", "bonific", "macrotask", "oracol", "sicur", "security", "secret", "segret"],
  "oracles": {
    "secret":          { "tool": "gitleaks", "shared": true },
    "dependency-vuln": { "tool": "osv", "lockfiles": ["package-lock.json", "pnpm-lock.yaml", "yarn.lock"] },
    "authz":           { "tool": "firestore_rules_check", "kind": "firestore-rules", "scan": ["."], "role": "authz-surface" },
    "injection":       { "tool": "semgrep", "ruleset": "ruleset/" }
  },
  "test_runner": { "detect": ["vitest", "jest", "mocha"] },
  "floor":        ["secret", "dependency-vuln", "authz"],
  "verified_set": [],
  "coverage_policy": "declared"
}
