node_modules/
eval/reference-app/
eval/.tmp-*/
.trueline/
*.log
dist/

# SP-1: per-ecosystem fixture apps are gitignored, on-disk inner repos (mirror eval/reference-app/)
eval/ecosystems/*/reference-app/

# BD-1 (T1.3): le reference-app dei fixture di build-discipline sono inner-repo con
# node_modules provvigionate offline (knip/typescript copiati dal canonico) -> gitignorate.
# I seeded-blueprint/ restano TRACKED (sono il materiale di gate del fixture).
eval/build-discipline/*/reference-app/

# AT-1 Fase A: le reference-app dei fixture anti-tamper sono inner-repo (node:test, zero
# npm install) provvigionati dall'orchestratore -> gitignorate. I seeded-blueprint/ restano
# TRACKED (sono il materiale di gate del fixture).
eval/anti-tamper/*/reference-app/

# A0: fixture del gate authz (control2 falso verde). I SORGENTI (open/scoped/shipit/_structural)
# sono materiale di gate -> TRACKED. Gli inner .git e i node_modules sono provvigionati a
# runtime dall'orchestratore (provision_fixtures.sh + npm install) -> gitignorati.
eval/ecosystems/_a0-fixtures/**/.git/
eval/ecosystems/_a0-fixtures/**/node_modules/

# A2a: fixture del gate igiene strutturale — sorgenti TRACKED (materiale di gate);
# inner .git e node_modules provvigionati a runtime dall'orchestratore -> gitignorati.
eval/ecosystems/_a2a-fixtures/**/.git/
eval/ecosystems/_a2a-fixtures/**/node_modules/
